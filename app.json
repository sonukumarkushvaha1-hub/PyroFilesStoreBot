{
  "name": "The Film Club Bot",
  "description": "A Telegram File Store Bot built with Hydrogram and MongoDB.",
  "repository": "https://github.com/SonuKushvaha/your-repo-name",
  "logo": "https://path-to-your-logo.png",
  "keywords": [
    "telegram",
    "bot",
    "hydrogram",
    "filestore"
  ],
  "env": {
    "API_ID": {
      "description": "Your Telegram API ID from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Your Telegram API HASH from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Your Bot Token from @BotFather",
      "required": true
    },
    "DB_CHANNEL": {
      "description": "Channel ID (starts with -100) where files will be stored",
      "required": true
    },
    "BOT_USERNAME": {
      "description": "Your bot's username without @",
      "required": true
    },
    "MONGODB_URI": {
      "description": "Your MongoDB Atlas connection string",
      "required": false
    }
  },
  "stack": "container",
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "free"
    }
  }
}
